{
  "name": "pet-viewer-for-codex",
  "displayName": "Pet Viewer for Codex",
  "description": "Display locally installed Codex pets in the VS Code Panel.",
  "version": "0.6.0",
  "publisher": "yutat23",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "yutat23"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yutat23/pet-viewer-for-codex.git"
  },
  "homepage": "https://github.com/yutat23/pet-viewer-for-codex#readme",
  "bugs": {
    "url": "https://github.com/yutat23/pet-viewer-for-codex/issues"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "codex",
    "pet",
    "mascot",
    "animation",
    "terminal"
  ],
  "activationEvents": [
    "onView:codexPet.panelView",
    "onCommand:codexPet.selectPet",
    "onCommand:codexPet.selectBackground",
    "onCommand:codexPet.setIdle",
    "onCommand:codexPet.setRunning",
    "onCommand:codexPet.setWaiting",
    "onCommand:codexPet.setReview",
    "onCommand:codexPet.setFailed",
    "onCommand:codexPet.refreshPets",
    "onCommand:codexPet.openPetsDirectory",
    "onCommand:codexPet.startAppServer",
    "onCommand:codexPet.stopAppServer",
    "onCommand:codexPet.restartAppServer",
    "onCommand:codexPet.installHooks",
    "onCommand:codexPet.uninstallHooks",
    "onCommand:codexPet.openHooksConfiguration"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "codexPet.panelContainer",
          "title": "PET",
          "icon": "media/paw.svg"
        }
      ]
    },
    "views": {
      "codexPet.panelContainer": [
        {
          "id": "codexPet.panelView",
          "name": "PET",
          "type": "webview",
          "icon": "media/paw.svg",
          "contextualTitle": "Pet Viewer for Codex"
        }
      ]
    },
    "commands": [
      {
        "command": "codexPet.selectPet",
        "title": "Change Pet",
        "category": "Pet Viewer for Codex",
        "icon": "$(list-selection)"
      },
      {
        "command": "codexPet.selectBackground",
        "title": "Change Background",
        "category": "Pet Viewer for Codex",
        "icon": "$(symbol-color)"
      },
      {
        "command": "codexPet.setIdle",
        "title": "Set State: Idle",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.setRunning",
        "title": "Set State: Running",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.setWaiting",
        "title": "Set State: Waiting",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.setReview",
        "title": "Set State: Review",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.setFailed",
        "title": "Set State: Failed",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.refreshPets",
        "title": "Refresh Pets",
        "category": "Pet Viewer for Codex",
        "icon": "$(refresh)"
      },
      {
        "command": "codexPet.openPetsDirectory",
        "title": "Open Pets Directory",
        "category": "Pet Viewer for Codex",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codexPet.previewPet",
        "title": "Open Pet Preview",
        "category": "Pet Viewer for Codex",
        "icon": "$(open-preview)"
      },
      {
        "command": "codexPet.startAppServer",
        "title": "Start Managed App Server",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.stopAppServer",
        "title": "Stop Managed App Server",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.restartAppServer",
        "title": "Restart Managed App Server",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.installHooks",
        "title": "Install Codex Hooks Integration",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.uninstallHooks",
        "title": "Uninstall Codex Hooks Integration",
        "category": "Pet Viewer for Codex"
      },
      {
        "command": "codexPet.openHooksConfiguration",
        "title": "Open Codex Hooks Configuration",
        "category": "Pet Viewer for Codex"
      }
    ],
    "menus": {
      "webview/context": [
        {
          "command": "codexPet.selectPet",
          "when": "(webviewId == 'codexPet.panelView' || webviewId == 'codexPet.preview') && webviewSection == 'pet'",
          "group": "navigation@1"
        },
        {
          "command": "codexPet.selectBackground",
          "when": "(webviewId == 'codexPet.panelView' || webviewId == 'codexPet.preview') && webviewSection == 'pet'",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "codexPet.refreshPets",
          "when": "view == codexPet.panelView",
          "group": "navigation@1"
        },
        {
          "command": "codexPet.openPetsDirectory",
          "when": "view == codexPet.panelView",
          "group": "navigation@2"
        },
        {
          "command": "codexPet.previewPet",
          "when": "view == codexPet.panelView",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Pet Viewer for Codex",
      "properties": {
        "codexPet.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Pet Viewer for Codex view."
        },
        "codexPet.petDirectory": {
          "type": "string",
          "default": "",
          "description": "Override the Pet directory. Leave empty to use CODEX_HOME/pets. Reload the window after changing it."
        },
        "codexPet.scale": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "Pet image size multiplier. The image still shrinks responsively when the PET view is smaller."
        },
        "codexPet.background": {
          "type": "string",
          "enum": ["none", "arcade", "autumn-forest", "blue-sky", "office", "pro-office", "grassland", "japanese-festival", "japanese-room", "living-room", "night-camp", "night-city", "space", "rainy-cafe", "treehouse", "server-room", "snowy-cabin", "sunset", "terminal", "tropical-beach", "underwater"],
          "enumDescriptions": [
            "Use the VS Code theme background.",
            "Neon arcade with colorful game cabinets.",
            "Golden forest path with drifting autumn leaves.",
            "Dreamy platform above the clouds.",
            "Warm office with a desk and books.",
            "Fully equipped modern software engineering office.",
            "Sunny meadow and distant hills.",
            "Japanese festival with lanterns, stalls, and fireworks.",
            "Traditional Japanese room with tatami and shoji.",
            "Comfortable living room with a soft rug.",
            "Starry campsite with mountains and a campfire.",
            "Neon skyline above a rain-wet rooftop.",
            "Outer space with a ringed planet and platform.",
            "Warm café interior beside a rainy window.",
            "Secret wooden hideaway in a giant tree.",
            "Cool server room with blinking rack lights.",
            "Warm cabin surrounded by falling snow.",
            "Warm sunset over mountains and a lake.",
            "Programmer terminal with commands typed live.",
            "Sunny tropical beach with palms and rolling waves.",
            "Bright coral garden beneath the sea."
          ],
          "default": "grassland",
          "description": "Background shown behind the Pet. You can also change it from the webview context menu."
        },
        "codexPet.animationSpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "Animation speed multiplier."
        },
        "codexPet.pauseWhenHidden": {
          "type": "boolean",
          "default": true,
          "description": "Pause animation while the Pet webview is hidden."
        },
        "codexPet.watchPetDirectory": {
          "type": "boolean",
          "default": true,
          "description": "Reload Pets automatically when files change."
        },
        "codexPet.integrationMode": {
          "type": "string",
          "enum": ["manual", "appServer", "hooks"],
          "enumDescriptions": [
            "Use state-changing commands only.",
            "Use the App Server managed by this extension.",
            "Reflect sessions from Codex Hooks, including the official Codex extension."
          ],
          "default": "manual",
          "description": "Choose manual commands, the managed App Server, or Codex Hooks integration."
        },
        "codexPet.appServer.executable": {
          "type": "string",
          "default": "codex",
          "description": "Codex CLI executable used for the managed App Server."
        },
        "codexPet.appServer.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the managed App Server automatically when integrationMode is appServer."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check && npm test && npm run build",
    "build": "node esbuild.mjs --production",
    "check": "tsc --noEmit",
    "compile": "node esbuild.mjs",
    "test": "vitest run",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
